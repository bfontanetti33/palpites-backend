# ── APIs externas ─────────────────────────────────────────────────
# Pegue em: https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=sua_chave_aqui
# Pegue em: https://console.anthropic.com
ANTHROPIC_API_KEY=sua_chave_aqui
# Pegue em: https://the-odds-api.com
ODDS_API_KEY=sua_chave_aqui

# ── Supabase ──────────────────────────────────────────────────────
# Pegue em: Supabase Dashboard → Settings → API
SUPABASE_URL=https://SEU_PROJETO_ID.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon_key_aqui
SUPABASE_JWT_SECRET=seu_jwt_secret_aqui

# ── Mercado Pago ──────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_aqui
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# ── Telegram (monitoramento automático) ───────────────────────────
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ── Sentry (captura de erros em produção) ────────────────────────
# Pegue em: sentry.io → seu projeto → Settings → DSN
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── Auth ──────────────────────────────────────────────────────────
PREMIUM_TOKEN=token-secreto-admin-troque-isso
ADMIN_TOKEN=token-admin-painel

# ── Anthropic — saldo (atualizar manualmente) ─────────────────────
# Alerta Telegram se < $2. Checar em: console.anthropic.com/billing
ANTHROPIC_CREDIT_REMAINING=10.00

# ── Lovable (CORS — legado) ───────────────────────────────────────
ALLOWED_ORIGIN=https://palpitesdaia.lovable.app
